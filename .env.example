PORT=8080
CORS_ORIGIN=http://localhost:5173

# Frontend API base URL (must match backend PORT, e.g. http://localhost:3000)
VITE_API_URL=http://localhost:3000

# Default model used by the frontend (must be one of /models)
DEFAULT_MODEL=llama3.1-8b-instruct

# llama.cpp server (Option A: one server, one GGUF at a time)
LLAMA_CPP_BASE_URL=http://localhost:8082
LLAMA_CPP_TIMEOUT_MS=60000
# Optional: override chat path if server uses different endpoint (default: v1/chat/completions)
# LLAMA_CPP_CHAT_PATH=v1/chat/completions

# Groq API (free tier — get key at https://console.groq.com)
# GROQ_API_KEY=gsk_...

# RAG Phase 2: vector store
# - memory (default): in-memory, no Docker; data lost on restart
# - qdrant: Qdrant at QDRANT_URL (run: docker run -p 6333:6333 qdrant/qdrant)
VECTOR_STORE=memory
# QDRANT_URL=http://localhost:6333

# Optional per-model overrides (keep unset for Option A)
# MODEL_LLAMA31_BASE_URL=
# MODEL_QWEN25_BASE_URL=
# MODEL_MISTRAL_BASE_URL=
# MODEL_PHI35_BASE_URL=